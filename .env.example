# App
APP_KEY=change-me-32-char-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
JWT_SECRET=change-me-jwt-secret

# Database (external Postgres server)
DATABASE_URL=postgresql://user:password@db-host:5432/orbit_docs

# Public URL (used to build git webhook URLs)
NUXT_PUBLIC_APP_URL=https://your-domain.com

# App base path when served behind a reverse proxy (e.g. /docs). Must be set at
# Docker BUILD time (see Dockerfile ARG) AND at runtime (docker-compose).
NUXT_APP_BASE_URL=/docs

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE_URL=   # override for Azure / custom proxy

# Opencode agent (required for doc generation)
# Base64-encoded opencode config.json — see implementation_plan.md for schema
OPENCODE_CONFIG_B64=

# --- Docker deployment vars ---
IMAGE_NAME=orbit-docs
APP_ENV=production
APP_HOST=your-domain.com
CI_REGISTRY_IMAGE=registry.gitlab.com/yourorg/orbit-docs
CI_COMMIT_TAG=latest
COMPOSE_REPLICAS=1
COMPOSE_PUBLIC_PORT=3000
