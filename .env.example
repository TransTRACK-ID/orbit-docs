# App
# GitLab CI builds the Docker image without these secrets; AWX injects them at
# deploy time via `.env`. Server code reads them from process.env at runtime.
APP_KEY=change-me-32-char-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
JWT_SECRET=change-me-jwt-secret

# Database (external Postgres server)
DATABASE_URL=postgresql://user:password@db-host:5432/orbit_docs

# Public URL (used to build git webhook URLs)
NUXT_PUBLIC_APP_URL=https://your-domain.com

# Postrack API Docs (server-side proxy for /api/api-docs)
NITRO_POSTRACK_API_URL=https://postrack.example.com
# NITRO_POSTRACK_API_KEY=   # optional if collections are public

# App base path when served behind a reverse proxy (e.g. /docs). Must be set at
# Docker BUILD time (see Dockerfile ARG) AND at runtime (docker-compose).
# NUXT_APP_BASE_URL is intentionally a build-time value for SPA asset URLs.
NUXT_APP_BASE_URL=/

# --- Doc chat (published pages /p/{id}) and doc generation (SRS/FSD/SDD) ---
# Doc generation uses DOC_AGENT (below). Chat uses CHAT_BACKEND:
#   auto (default) — OpenRouter/OpenAI when OPENAI_API_KEY is set, else Cursor CLI
#   openrouter     — always use OPENAI_API_KEY (fast token streaming)
#   cursor         — always use cursor-agent ask mode (same auth as DOC_AGENT)
CHAT_BACKEND=auto

# Fast streaming chat (recommended for /p/{id} AI chat)
OPENAI_API_KEY=sk-or-v1-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE_URL=https://openrouter.ai/api/v1

# Agent backend for doc generation + chat fallback: 'cursor' (default) | 'opencode'
DOC_AGENT=cursor
# Exposed to the UI at runtime (docker-compose sets this from DOC_AGENT)
NUXT_PUBLIC_DOC_AGENT=cursor

# Cursor agent (required when DOC_AGENT=cursor — default)
# Authentication — choose ONE of the following:
#   1. Interactive login (development): run 'cursor-agent login' on the host
#   2. API key (production / headless): set CURSOR_API_KEY below
CURSOR_API_KEY=

# Set a specific model, or 'auto' to let Cursor choose.
# Available: auto, composer-2.5, opus-4.8, gpt-5.5, sonnet-4, sonnet-4-thinking, gemini-3.1-pro, grok-4.3
CURSOR_MODEL=auto

# Opencode agent (only when DOC_AGENT=opencode)
# Base64-encoded opencode config.json — see implementation_plan.md for schema.
OPENCODE_CONFIG_B64=

# --- Optional: legacy OpenAI-compatible API (not used by /api/chat) ---
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE_URL=https://openrouter.ai/api/v1

# OP / Apps Script feature sync uses the Production API key from Settings → API Keys
# (Authorization: Bearer od_live_...). See docs/OP_FEATURE_SYNC.md.

# --- Docker deployment vars ---
# Git clones are stored under ORBIT_REPO_DIR inside the container (default:
# /home/nodejs/.local/share/orbit-docs-repositories). The compose file mounts a
# named volume there — do not bind-mount /tmp/orbit-docs-repositories.
IMAGE_NAME=orbit-docs
APP_ENV=production
APP_HOST=your-domain.com
CI_REGISTRY_IMAGE=registry.gitlab.com/yourorg/orbit-docs
CI_COMMIT_TAG=latest
COMPOSE_REPLICAS=1
COMPOSE_PUBLIC_PORT=3000
