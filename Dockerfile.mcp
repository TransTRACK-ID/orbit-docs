# Orbit Docs MCP Server
# Standalone Dockerfile for the MCP HTTP server

FROM node:22-alpine

WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./

# Install only production dependencies + tsx
RUN npm ci --omit=dev && npm install tsx

# Copy required source files
COPY mcp-server.ts ./
COPY tsconfig.mcp.json ./
COPY server/database/schema ./server/database/schema
COPY .env ./

# Expose the MCP port
EXPOSE 41244

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:41244/health || exit 1

# Start the MCP server
CMD ["npx", "tsx", "mcp-server.ts"]
